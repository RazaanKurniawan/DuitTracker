# Contoh environment variables untuk production
# Copy file ini ke .env dan isi nilainya

# --- Opsi 1: Koneksi via DATABASE_URL (Render/Neon/Supabase) ---
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# --- Opsi 2: Koneksi manual (local dev) ---
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=postgres
# DB_PASSWORD=12345
# DB_NAME=pengeluaran_db

# Server
PORT=3000

# JWT secret - ganti dengan string random yang panjang!
JWT_SECRET=ganti_dengan_string_secret_yang_panjang_dan_random

# CORS - URL frontend yang diizinkan (pisah koma, atau * untuk semua)
# Contoh: https://duittracker.vercel.app,https://duittracker.netlify.app
ALLOWED_ORIGINS=*
